{
    "compilerOptions": {
        "declaration": true,
        "jsx": "react",
        "lib": [ "dom", "es2020" ],
        "declarationDir": "./dts",
        "sourceMap": true,
        "strict": true,
        "strictNullChecks": false,
        "preserveValueImports": false,
        "importsNotUsedAsValues": "remove",
        "verbatimModuleSyntax": true,
        "module": "ES2022",
        "target": "ES2020",
        "moduleResolution": "node",
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "skipLibCheck": true
    },
    "exclude": [
        "node_modules"
    ],
    "include": [ "src/**/*" ]
}
